{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Configure CMake",
      "type": "shell",
      "command": "cmake",
      "args": [
        "-S",
        ".",
        "-G",
        "Visual Studio 17 2022",
        "-A",
        "x64",
        "-B",
        "build-vs"
      ],
      "problemMatcher": []
    },
    {
      "label": "Build Debug",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build",
        "build-vs",
        "--config",
        "Debug"
      ],
      "problemMatcher": [
        "$msCompile"
      ],
      "group": "build",
      "dependsOn": "Configure CMake"
    },
    {
      "label": "Run DJ-ROOFRAT",
      "type": "shell",
      "command": "build-vs\\Debug\\DJ-ROOFRAT.exe",
      "args": [
        "--no-audio"
      ],
      "problemMatcher": [],
      "dependsOn": "Build Debug"
    }
  ]
}
